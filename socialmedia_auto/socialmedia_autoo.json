      "parameters": {
        "jsCode": "// Get raw text output from Gemini\nlet raw = $json.text || \"\";\n\n// Remove ```json and ``` if present\nraw = raw.replace(/```json/g, \"\").replace(/```/g, \"\").trim();\n\n// Parse JSON safely\nlet parsed;\n\ntry {\n  parsed = JSON.parse(raw);\n} catch (error) {\n  throw new Error(\"Invalid JSON from Gemini: \" + raw);\n}\n\n// Return structured fields\nreturn {\n  topic: $('Get row(s) in sheet').first().json.Topic,\n  ig_caption: parsed.ig_caption,\n  li_caption: parsed.li_caption,\n  fb_caption: parsed.fb_caption,\n  yt_title: parsed.yt_title,\n  yt_desc: parsed.yt_desc,\n  hashtags: parsed.hashtags,\n  cta: parsed.cta,\n  image_prompt: parsed.image_prompt\n};"
      },
