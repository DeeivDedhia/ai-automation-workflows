    {
      "parameters": {
        "jsCode": "// Get all incoming merged items\nconst items = $input.all();\n\n// Create a clean output object\nlet outputData = {\n  success: true,\n  platforms: {}\n};\n\n// Loop through all merged inputs\nfor (const item of items) {\n  const data = item.json;\n\n  // Detect platform by keys\n  if (data.fb_caption || data.facebook) {\n    outputData.platforms.facebook = data;\n  }\n\n  if (data.li_caption || data.linkedin) {\n    outputData.platforms.linkedin = data;\n  }\n\n  if (data.yt_title) {\n    outputData.platforms.youtube = data;\n  }\n\n  if (data.ig_caption) {\n    outputData.platforms.instagram = data;\n  }\n}\n\n// Final return\nreturn [\n  {\n    json: {\n      output: true,\n      data: outputData\n    }\n  }\n];"
      },
